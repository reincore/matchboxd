# Matchboxd environment variables
#
# NOTE: This app is client-side only. Any VITE_* variable you define here will be
# bundled into the static JavaScript and is therefore publicly readable once the
# app is deployed. Only use keys whose exposure you are comfortable with.

# --- TMDB ---
# Your TMDB v3 API key. Get one at https://www.themoviedb.org/settings/api
# Without this the app runs in "limited" mode (no posters, no synopses, no providers).
VITE_TMDB_API_KEY=

# --- Letterboxd RSS access ---
# Letterboxd exposes per-user public RSS feeds. Browsers cannot fetch them directly
# because of CORS, so we read them through an adapter. Supported adapters:
#   - rss2json   Uses https://api.rss2json.com/v1/api.json (no key needed, rate limited)
#   - allorigins Uses https://api.allorigins.win/raw (public CORS proxy)
#   - custom     You host your own proxy and point VITE_RSS_BASE_URL at it
VITE_RSS_ADAPTER=allorigins

# Only used when VITE_RSS_ADAPTER=custom. Your proxy must return raw XML and
# accept ?url=<encoded-letterboxd-rss-url> as a query parameter.
VITE_RSS_BASE_URL=

# --- Deployment ---
# Base path for the app. For a custom domain at the root, use "/".
# For a GitHub project page like https://<user>.github.io/matchboxd/, use "/matchboxd/".
VITE_APP_BASE_PATH=/
