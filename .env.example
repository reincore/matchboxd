# Matchboxd environment variables
#
# NOTE: This app is client-side only. Any VITE_* variable you define here will be
# bundled into the static JavaScript and is therefore publicly readable once the
# app is deployed. Only use keys whose exposure you are comfortable with.

# --- Letterboxd scraping proxy ---
# Matchboxd scrapes public Letterboxd HTML pages through a proxy chain.
# Supported modes:
#   - auto   Use the local dev proxy on localhost, otherwise the hosted worker
#   - custom Prepend your own proxy base URL ahead of the controlled defaults
VITE_LETTERBOXD_PROXY_MODE=auto

# Only used when VITE_LETTERBOXD_PROXY_MODE=custom.
# Your proxy must return raw HTML and accept ?url=<encoded-letterboxd-url>.
VITE_LETTERBOXD_PROXY_BASE_URL=

# Public proxy fallbacks are disabled by default so production prefers the
# controlled worker path. Set this to true only if you explicitly want them.
VITE_ENABLE_PUBLIC_PROXY_FALLBACKS=false

# --- Deployment ---
# Base path for the app. For a custom domain at the root, use "/".
# For a GitHub project page like https://<user>.github.io/matchboxd/, use "/matchboxd/".
VITE_APP_BASE_PATH=/

# --- Deprecated aliases (temporary migration support) ---
# VITE_RSS_ADAPTER=custom
# VITE_RSS_BASE_URL=https://your-proxy.example.com
